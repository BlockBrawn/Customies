{
	"name": "customiesdevs/customies",
	"description": "Creates Custom Items & Block in Pocketmine-MP (Fork)",
	"version": "1.5.0",
	"type": "library",
	"license": "MIT",
	"minimum-stability": "dev",
	"prefer-stable": true,
	"autoload": {
		"classmap": ["src"]
	},
	"scripts": {
		"build": [
			"@php -dphar.readonly=0 ./vendor/bin/pharynx -i . -c -p=Customies.phar"
		]
	},
	"require-dev": {
		"nethergamesmc/pocketmine-mp": "dev-stable",
		"sof3/pharynx": "dev-master"
	},
	"repositories": [
		{
			"type": "vcs",
			"url": "git@github.com:NetherGamesMC/PocketMine-MP.git"
		}
	],
	"config": {
		"sort-packages": true,
		"allow-plugins": {
			"phpstan/extension-installer": true
		}
	},
	"authors": [
		{
			"name": "JeanTKG",
			"email": "jeantkg@gmail.com",
			"role": "Fork-Developer",
			"homepage": "https://discord.gg/s2yj8Thvba"
		}
	]
}